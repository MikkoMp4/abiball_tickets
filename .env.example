# Abiball Tickets – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.

# Server
PORT=3000

# Datenbankverzeichnis (SQLite) – als Docker-Volume mounten
DATA_DIR=/data

# SMTP (E-Mail-Versand)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=dein@email.de
SMTP_PASS=geheimes_passwort
MAIL_FROM="Abiball Tickets <tickets@schule.de>"

# Bankdaten (für EPC/Girocode-Generierung)
BANK_IBAN=DE00 1234 5678 9012 3456 78
BANK_BIC=XXXXXXXX
BANK_NAME=Abiball-Komitee e.V.

# Ticket-Preis in Euro
TICKET_PRICE=45
